import java.util.ArrayList;
import java.util.List;

public class RPGManagerTodoEnUno {

    public static void main(String[] args) {
        Personaje guerrero = new Guerrero("Thor", 5);
        Personaje mago = new Mago("Merlín", 4);
        Personaje arquero = new Arquero("Legolas", 6);
        Enemigo orco = new Enemigo("Orco Jefe", 120);

        List<Personaje> heroes = new ArrayList<>();
        heroes.add(guerrero);
        heroes.add(mago);
        heroes.add(arquero);

        System.out.println("=== ESTADO INICIAL ===");
        mostrarEstado(heroes, orco);

        System.out.println("\n=== ATAQUES NORMALES (POLIMORFISMO) ===");
        for (Personaje heroe : heroes) {
            heroe.atacar(orco);
        }

        System.out.println("\n=== HABILIDADES ESPECIALES E INTERFACES ===");
        for (Personaje heroe : heroes) {
            if (heroe instanceof Habilidoso) {
                ((Habilidoso) heroe).usarHabilidadEspecial(orco);
            }

            if (heroe instanceof Sanador) {
                ((Sanador) heroe).sanar(guerrero);
            }

            if (heroe instanceof Equipable) {
                ((Equipable) heroe).equipar("Ítem épico");
            }
        }

        System.out.println("\n=== ESTADO FINAL ===");
        mostrarEstado(heroes, orco);
    }

    static void mostrarEstado(List<Personaje> heroes, Enemigo enemigo) {
        for (Personaje heroe : heroes) {
            System.out.println(heroe);
        }
        System.out.println(enemigo);
    }

    interface Habilidoso {
        void usarHabilidadEspecial(Enemigo objetivo);
    }

    interface Equipable {
        void equipar(String item);
    }

    interface Sanador {
        void sanar(Personaje aliado);
    }

    static abstract class Personaje {
        protected String nombre;
        protected int nivel;
        protected int puntosVida;

        public Personaje(String nombre, int nivel, int puntosVida) {
            this.nombre = nombre;
            this.nivel = nivel;
            this.puntosVida = puntosVida;
        }

        public void recibirDano(int dano) {
            puntosVida = Math.max(0, puntosVida - dano);
        }

        public void curar(int puntos) {
            puntosVida += puntos;
        }

        public abstract void atacar(Enemigo objetivo);

        @Override
        public String toString() {
            return getClass().getSimpleName() + " {nombre='" + nombre + "', nivel=" + nivel + ", vida=" + puntosVida + "}";
        }
    }

    static class Guerrero extends Personaje implements Habilidoso, Equipable {
        private int fuerza;
        private int defensa;

        public Guerrero(String nombre, int nivel) {
            super(nombre, nivel, 100 + nivel * 10);
            this.fuerza = 15 + nivel * 2;
            this.defensa = 10 + nivel;
        }

        @Override
        public void atacar(Enemigo objetivo) {
            int dano = fuerza;
            objetivo.recibirDano(dano);
            System.out.println(nombre + " ataca con espada y hace " + dano + " de daño.");
        }

        @Override
        public void usarHabilidadEspecial(Enemigo objetivo) {
            int dano = fuerza + 20;
            objetivo.recibirDano(dano);
            System.out.println(nombre + " usa Golpe Devastador y hace " + dano + " de daño.");
        }

        @Override
        public void equipar(String item) {
            defensa += 5;
            System.out.println(nombre + " equipa " + item + " y sube su defensa a " + defensa + ".");
        }
    }

    static class Mago extends Personaje implements Habilidoso, Sanador {
        private int mana;
        private int manaMax;

        public Mago(String nombre, int nivel) {
            super(nombre, nivel, 60 + nivel * 5);
            this.manaMax = 100 + nivel * 10;
            this.mana = manaMax;
        }

        @Override
        public void atacar(Enemigo objetivo) {
            int dano = 12 + nivel * 3;
            objetivo.recibirDano(dano);
            System.out.println(nombre + " lanza hechizo y hace " + dano + " de daño.");
        }

        @Override
        public void usarHabilidadEspecial(Enemigo objetivo) {
            if (mana >= 20) {
                int dano = 30 + nivel * 4;
                mana -= 20;
                objetivo.recibirDano(dano);
                System.out.println(nombre + " usa Bola de Fuego y hace " + dano + " de daño. Mana restante: " + mana);
            } else {
                System.out.println(nombre + " no tiene suficiente mana para Bola de Fuego.");
            }
        }

        @Override
        public void sanar(Personaje aliado) {
            if (mana >= 15) {
                int cura = 25 + nivel * 2;
                mana -= 15;
                aliado.curar(cura);
                System.out.println(nombre + " sana a " + aliado.nombre + " por " + cura + " puntos. Mana restante: " + mana);
            } else {
                System.out.println(nombre + " no tiene suficiente mana para sanar.");
            }
        }
    }

    static class Arquero extends Personaje implements Equipable {
        private int flechas;
        private int alcance;

        public Arquero(String nombre, int nivel) {
            super(nombre, nivel, 75 + nivel * 7);
            this.flechas = 10 + nivel;
            this.alcance = 20 + nivel * 2;
        }

        @Override
        public void atacar(Enemigo objetivo) {
            if (flechas > 0) {
                int dano = 14 + nivel * 2;
                flechas--;
                objetivo.recibirDano(dano);
                System.out.println(nombre + " dispara una flecha y hace " + dano + " de daño. Flechas restantes: " + flechas);
            } else {
                System.out.println(nombre + " no tiene flechas.");
            }
        }

        @Override
        public void equipar(String item) {
            alcance += 5;
            flechas += 3;
            System.out.println(nombre + " equipa " + item + ", aumenta su alcance a " + alcance + " y ahora tiene " + flechas + " flechas.");
        }
    }

    static class Enemigo {
        private String nombre;
        private int puntosVida;

        public Enemigo(String nombre, int puntosVida) {
            this.nombre = nombre;
            this.puntosVida = puntosVida;
        }

        public void recibirDano(int dano) {
            puntosVida = Math.max(0, puntosVida - dano);
        }

        @Override
        public String toString() {
            return "Enemigo {nombre='" + nombre + "', vida=" + puntosVida + "}";
        }
    }
}
